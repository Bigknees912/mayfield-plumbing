# Env vars for the future frontend (not the receptionist-server, which has
# its own .env.example for Vapi/webhook secrets). Vite-style naming (VITE_
# prefix) since app-demo.jsx has no framework-specific imports; adjust the
# prefix if a different bundler is chosen later.

VITE_SUPABASE_URL=https://umtoseyxvszdxbuvuyuk.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_DzyllacMgWg-TUMMO2-c2Q_YYzaS-lM

# Error tracking (see AUTH.md "Error tracking (Sentry)"). Optional - if
# unset, src/lib/sentry.js's initSentry() just does nothing, same as
# every other integration in this app when its secret isn't configured
# yet. Create a project at sentry.io, choose "React", and copy its DSN
# here.
VITE_SENTRY_DSN=

# Server-only. Get from Supabase dashboard -> Project Settings -> API.
# Bypasses RLS entirely - never expose to the browser. Used by:
#  - the marketing site's lead form handler (inserts into `leads`)
#  - receptionist-server (inserts into `calls`, and `jobs` on booking)
# SUPABASE_SERVICE_ROLE_KEY=
