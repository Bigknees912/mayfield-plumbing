# REQUIRED (server.js refuses all webhook traffic with a 503 if unset -
# this isn't optional hardening, it's the only thing standing between
# your webhook and anyone on the internet who finds the URL, since it
# creates real jobs/customers and can trigger real SMS spend). Generate
# any random string, put it here, and add the same value as an
# Authorization: Bearer header in Vapi's tool "server" credential config.
VAPI_WEBHOOK_SECRET=

# Your Vapi private API key, used only for the setup curl commands in README.md,
# not read by server.js itself.
VAPI_API_KEY=

# Same Supabase project the dashboard app uses. URL is public (see the root
# .env.example). The service_role key is NOT - it bypasses every RLS policy,
# since this server has no logged-in user to scope queries to. Get it from
# the Supabase dashboard: Project Settings -> API -> service_role secret.
# Never commit it, never put it anywhere client-side.
SUPABASE_URL=https://umtoseyxvszdxbuvuyuk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# The company this deployed instance answers calls for. One deployed
# instance = one company (see README's resale model). There's no company
# to point at until someone has signed up as owner through the dashboard
# app - do that first, then find the id: Supabase dashboard -> Table
# Editor -> companies -> copy the `id` column for the row you want.
SUPABASE_COMPANY_ID=

PORT=3000

# Error tracking (see AUTH.md "Error tracking (Sentry)"). Optional - if
# unset, errors just log to the console/Render logs like before, same as
# every other integration in this app when its secret isn't configured
# yet. Create a project at sentry.io, choose "Node.js" / "Express", and
# copy its DSN here.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
