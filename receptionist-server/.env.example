# Optional: protects your webhook so only Vapi can call it.
# Generate any random string, put it here, and add the same value as an
# Authorization: Bearer header in Vapi's tool "server" credential config.
VAPI_WEBHOOK_SECRET=

# Your Vapi private API key, used only for the setup curl commands in README.md,
# not read by server.js itself.
VAPI_API_KEY=

PORT=3000
